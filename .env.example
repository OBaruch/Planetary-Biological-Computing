GAIA_MODE=simulator
GAIA_TICKS_PER_SECOND=10
GAIA_HISTORY_LIMIT=1000
GAIA_LOG_TO_FILE=true
GAIA_SESSION_NAME=local_demo
# Planet data mode: "live" = strict real data (only configured sources show),
# "demo" = legacy simulated planet + demo globe events.
GAIA_DATA_MODE=live
GAIA_USE_LIVE_DATA=false
GAIA_ALLOW_FALLBACK=true
GAIA_AUTOSTART=false

# API keys are normally configured per-user from the in-app Settings panel
# (stored in backend/data/credentials.json, gitignored). As an alternative you
# can provide them here as GAIA_KEY_<SOURCE>_<FIELD>, e.g.:
# GAIA_KEY_FIRMS_MAP_KEY=your_firms_map_key
# GAIA_KEY_OPENWEATHER_API_KEY=your_openweather_key
# GAIA_KEY_OPENAQ_API_KEY=your_openaq_key

GAIA_ENABLE_CL_RECORDING=false
GAIA_ENABLE_CL_DATA_STREAM=true
GAIA_ENABLE_CL_STIMULATION=false
GAIA_CL_RECORDING_SECONDS=0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

CL_SDK_RANDOM_SEED=42
CL_SDK_VISUALISATION=1
CL_SDK_ACCELERATED_TIME=0
CL_SDK_SPIKE_VISIBILITY=1

VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/live
